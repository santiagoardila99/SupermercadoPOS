{
  "name": "supermercado-pos-desktop",
  "version": "1.0.0",
  "description": "SupermercadoPOS — App de escritorio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.supermercadopos.app",
    "productName": "SupermercadoPOS",
    "directories": {
      "output": "dist-desktop"
    },
    "win": {
      "target": "nsis",
      "icon": "../frontend/public/icon-512.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "../frontend/public/icon-512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "../frontend/public/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "../frontend/public/icon-512.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SupermercadoPOS"
    },
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!node_modules", "!data"]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ]
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
