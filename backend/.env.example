# ─── SupermercadoPOS — Variables de entorno ───────────────────────────────────
# Copia este archivo como .env y completa los valores

PORT=3001
NODE_ENV=development

# CAMBIA ESTO — genera uno en: https://generate-secret.vercel.app/64
JWT_SECRET=cambia_esto_por_algo_muy_largo_y_aleatorio_minimo_32_caracteres

# Ruta BD: en produccion (Render) usa /data, en dev deja vacio
# DB_PATH=/data

# Origenes CORS (en dev se permite todo, en prod pon tu dominio)
# ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# IA opcional
# OPENAI_API_KEY=sk-...
